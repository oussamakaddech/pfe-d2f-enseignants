r\n        (s) =>\r\n          String(s.competenceId) === String(competenceId)\r\n          && (s.sousCompetenceId == null || s.sousCompetenceId === \"\"),\r\n      )\r\n      .map(toSavoirNode);\r\n\r\n  const buildScChildren = (competenceId, parentScId = null) => {\r\n    const nodes = sousComps.filter(\r\n      (sc) =>\r\n        String(sc.competenceId) === String(competenceId) &&\r\n        (parentScId === null\r\n          ? sc.parentId == null\r\n          : String(sc.parentId) === String(parentScId)),\r\n    );\r\n\r\n    return nodes.map((sc) => {\r\n      const childSc = buildScChildren(competenceId, sc.id);\r\n      const leafSavoirs =\r\n        childSc.length === 0\r\n          ? savoirs\r\n              .filter((s) => String(s.sousCompetenceId) === String(sc.id))\r\n              .map(toSavoirNode)\r\n          : [];\r\n\r\n      return {\r\n        name: sc.nom,\r\n        attributes: { code: sc.code },\r\n        children: [...childSc, ...leafSavoirs],\r\n      };\r\n    });\r\n  };\r\n\r\n  return {\r\n    name: \"Referentiel\",\r\n    children: (domaines || []).map((d) => ({\r\n      name: d.nom,\r\n      attributes: { code: d.code },\r\n      children: (competences || [])\r\n        .filter((c) => String(c.domaineId) === String(d.id))\r\n        .map((c) => {\r\n          const scChildren = buildScChildren(c.id, null);\r\n          const directSavoirs = getDirectSavoirs(c.id);\r\n          return {\r\n            name: c.nom,\r\n            attributes: { code: c.code },\r\n            children: [...scChildren, ...directSavoirs],\r\n          };\r\n        }),\r\n    })),\r\n  };\r\n}\r\n\r\nexport function buildMatrixRows(matrixData = {}) {\r\n  const maxRows = Math.max(\r\n    ...NIVEAUX_MATRIX.map((n) => (matrixData?.[n.key] || []).length),\r\n    1,\r\n  );\r\n\r\n  return Array.from({ length: maxRows }, (_, idx) => {\r\n    const row = {};\r\n    NIVEAUX_MATRIX.forEach((n) => {\r\n      row[n.label] = matrixData?.[n.key]?.[idx]?.savoirCode || \"\";\r\n    });\r\n    return row;\r\n  });\r\n}\r\n\r\nexport function buildExportFileName(competenceCode, date = new Date()) {\r\n  const safeCode = (competenceCode || \"competence\")\r\n    .replaceAll(/[^A-Za-z0-9_-]/g, \"_\")\r\n    .slice(0, 40);\r\n  const isoDate = date.toISOString().slice(0, 10);\r\n  return `affectation_niveaux_${safeCode}_${isoDate}.xlsx`;\r\n}\r\n"],"mappings":"AAAO,aAAM,iBAAiB;AAAA,EAC5B,EAAE,KAAK,eAAe,OAAO,MAAM;AAAA,EACnC,EAAE,KAAK,kBAAkB,OAAO,MAAM;AAAA,EACtC,EAAE,KAAK,oBAAoB,OAAO,MAAM;AAAA,EACxC,EAAE,KAAK,aAAa,OAAO,MAAM;AAAA,EACjC,EAAE,KAAK,aAAa,OAAO,MAAM;AACnC;AAEO,gBAAS,gBAAgB,WAAW,CAAC,GAAG,cAAc,CAAC,GAAG,YAAY,CAAC,GAAG,UAAU,CAAC,GAAG;AAC7F,QAAM,eAAe,CAAC,OAAO;AAAA,IAC3B,MAAM,EAAE;AAAA,IACR,YAAY,EAAE,MAAM,EAAE,MAAM,MAAM,EAAE,KAAK;AAAA,EAC3C;AAEA,QAAM,mBAAmB,CAAC,iBACxB,QACG;AAAA,IACC,CAAC,MACC,OAAO,EAAE,YAAY,MAAM,OAAO,YAAY,MAC1C,EAAE,oBAAoB,QAAQ,EAAE,qBAAqB;AAAA,EAC7D,EACC,IAAI,YAAY;AAErB,QAAM,kBAAkB,CAAC,cAAc,aAAa,SAAS;AAC3D,UAAM,QAAQ,UAAU;AAAA,MACtB,CAAC,OACC,OAAO,GAAG,YAAY,MAAM,OAAO,YAAY,MAC9C,eAAe,OACZ,GAAG,YAAY,OACf,OAAO,GAAG,QAAQ,MAAM,OAAO,UAAU;AAAA,IACjD;AAEA,WAAO,MAAM,IAAI,CAAC,OAAO;AACvB,YAAM,UAAU,gBAAgB,cAAc,GAAG,EAAE;AACnD,YAAM,cACJ,QAAQ,WAAW,IACf,QACG,OAAO,CAAC,MAAM,OAAO,EAAE,gBAAgB,MAAM,OAAO,GAAG,EAAE,CAAC,EAC1D,IAAI,YAAY,IACnB,CAAC;AAEP,aAAO;AAAA,QACL,MAAM,GAAG;AAAA,QACT,YAAY,EAAE,MAAM,GAAG,KAAK;AAAA,QAC5B,UAAU,CAAC,GAAG,SAAS,GAAG,WAAW;AAAA,MACvC;AAAA,IACF,CAAC;AAAA,EACH;AAEA,SAAO;AAAA,IACL,MAAM;AAAA,IACN,WAAW,YAAY,CAAC,GAAG,IAAI,CAAC,OAAO;AAAA,MACrC,MAAM,EAAE;AAAA,MACR,YAAY,EAAE,MAAM,EAAE,KAAK;AAAA,MAC3B,WAAW,eAAe,CAAC,GACxB,OAAO,CAAC,MAAM,OAAO,EAAE,SAAS,MAAM,OAAO,EAAE,EAAE,CAAC,EAClD,IAAI,CAAC,MAAM;AACV,cAAM,aAAa,gBAAgB,EAAE,IAAI,IAAI;AAC7C,cAAM,gBAAgB,iBAAiB,EAAE,EAAE;AAC3C,eAAO;AAAA,UACL,MAAM,EAAE;AAAA,UACR,YAAY,EAAE,MAAM,EAAE,KAAK;AAAA,UAC3B,UAAU,CAAC,GAAG,YAAY,GAAG,aAAa;AAAA,QAC5C;AAAA,MACF,CAAC;AAAA,IACL,EAAE;AAAA,EACJ;AACF;AAEO,gBAAS,gBAAgB,aAAa,CAAC,GAAG;AAC/C,QAAM,UAAU,KAAK;AAAA,IACnB,GAAG,eAAe,IAAI,CAAC,OAA