:1,"8":1,"9":1,"10":1,"11":1,"12":1,"13":1,"14":1,"15":0,"16":0,"17":0},"f":{"0":1,"1":1,"2":1,"3":1,"4":1,"5":0,"6":0},"b":{},"inputSourceMap":{"version":3,"sources":["C:/Users/oussama/Desktop/pfe-d2f-enseignants/esprit_D2F-webapp/src/services/auth/AuthService.ts"],"sourcesContent":["import type { AxiosResponse } from \"axios\";\nimport { createApiClient } from \"@/utils/helpers/httpClient\";\n\nimport { config } from \"@/config/env\";\nimport type {\n  LoginRequest,\n  LoginResponse,\n  ResetPasswordRequest,\n  SignupRequest,\n  AuthUser,\n} from \"@/models/auth\";\n\nconst api = createApiClient(`${config.URL_ACCOUNT}/auth`);\n\n/**\n * Authenticate user. JWT is set as HttpOnly cookie by the server.\n * Body returns only userId, role, email, expiresIn — NO token.\n */\nexport async function login({\n  username,\n  password,\n}: LoginRequest): Promise<LoginResponse> {\n  const params = new URLSearchParams();\n  params.append(\"username\", username);\n  params.append(\"password\", password);\n  const response: AxiosResponse<LoginResponse> = await api.post(\n    `/login`,\n    params\n  );\n\n  // JWT is now in HttpOnly cookie — no localStorage\n  return response.data;\n}\n\nexport async function signup(payload: SignupRequest): Promise<unknown> {\n  const response = await api.post(\"/signup\", payload);\n  return response.data;\n}\n\nexport async function forgotPassword(emailAddress: string): Promise<unknown> {\n  const url = `/forgot-password?emailAddress=${encodeURIComponent(\n    emailAddress\n  )}`;\n  const response = await api.post(url);\n  return response.data;\n}\n\nexport async function resetPassword({\n  confirmationKey,\n  newPassword,\n}: ResetPasswordRequest): Promise<unknown> {\n  const response = await api.post(`/reset-password`, {\n    confirmationKey,\n    newPassword,\n  });\n  return response.data;\n}\n\nexport async function getProfile(): Promise<AuthUser> {\n  const response = await api.get(\"/profile\");\n  return response.data;\n}\n\n/**\n * Refresh JWT cookie silently. Server validates existing cookie\n * and returns a new one.\n */\nexport async function refreshToken(): Promise<LoginResponse> {\n  const response: AxiosResponse<LoginResponse> = await api.get(\"/refresh\");\n  return response.data;\n}\n\n/**\n * Logout — server invalidates the HttpOnly cookie (Max-Age=0).\n */\nexport async function logout(): Promise<void> {\n  await api.post(\"/logout\");\n}\n\n\n\n\n"],"mappings":"AACA,SAAS,uBAAuB;AAEhC,SAAS,cAAc;AASvB,MAAM,MAAM,gBAAgB,GAAG,OAAO,WAAW,OAAO;AAMxD,sBAAsB,MAAM;AAAA,EAC1B;AAAA,EACA;AACF,GAAyC;AACvC,QAAM,SAAS,IAAI,gBAAgB;AACnC,SAAO,OAAO,YAAY,QAAQ;AAClC,SAAO,OAAO,YAAY,QAAQ;AAClC,QAAM,WAAyC,MAAM,IAAI;AAAA,IACvD;AAAA,IACA;AAAA,EACF;AAGA,SAAO,SAAS;AAClB;AAEA,sBAAsB,OAAO,SAA0C;AACrE,QAAM,WAAW,MAAM,IAAI,KAAK,WAAW,OAAO;AAClD,SAAO,SAAS;AAClB;AAEA,sBAAsB,eAAe,cAAwC;AAC3E,QAAM,MAAM,iCAAiC;AAAA,IAC3C;AAAA,EACF,CAAC;AACD,QAAM,WAAW,MAAM,IAAI,KAAK,GAAG;AACnC,SAAO,SAAS;AAClB;AAEA,sBAAsB,cAAc;AAAA,EAClC;AAAA,EACA;AACF,GAA2C;AACzC,QAAM,WAAW,MAAM,IAAI,KAAK,mBAAmB;AAAA,IACjD;AAAA,IACA;AAAA,EACF,CAAC;AACD,SAAO,SAAS;AAClB;AAEA,sBAAsB,aAAgC;AACpD,QAAM,WAAW,MAAM,IAAI,IAAI,UAAU;AACzC,SAAO,SAAS;AAClB;AAMA,sBAAsB,eAAuC;AAC3D,QAAM,WAAyC,MAAM,IAAI,IAAI,UAAU;AACvE,SAAO,SAAS;AAClB;AAKA,sBAAsB,SAAwB;AAC5C,QAAM,IAAI,KAAK,SAAS;AAC1B;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"cc8ee3d8c25486b34f74993e85131b336cf49bd7"}}