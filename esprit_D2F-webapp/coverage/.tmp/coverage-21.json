 }\r\n\r\n    const { data } = await axios.put(`${API_URL}/${id}`, formData);\r\n    return data;\r\n  },\r\n\r\n  async deleteDocument(id: number | string) {\r\n    await axios.delete(`${API_URL}/${id}`);\r\n  },\r\n\r\n  async downloadDocument(id: number | string) {\r\n    const response = await axios.get(`${API_URL}/download/${id}`, {\r\n      responseType: \"blob\",\r\n    });\r\n\r\n    const disposition = response.headers[\"content-disposition\"];\r\n    let filename = \"document\";\r\n    if (disposition) {\r\n      const match = disposition.match(/filename=\"?(.+?)\"?$/);\r\n      if (match) filename = match[1];\r\n    }\r\n\r\n    const url = globalThis.URL.createObjectURL(new Blob([response.data]));\r\n    const link = document.createElement(\"a\");\r\n    try {\r\n      link.href = url;\r\n      link.setAttribute(\"download\", filename);\r\n      document.body.appendChild(link);\r\n      link.click();\r\n    } finally {\r\n      link.remove();\r\n      globalThis.URL.revokeObjectURL(url);\r\n    }\r\n  },\r\n};\r\n\r\nexport default DocumentService;\r\n\r\n\r\n\r\n\r\n"],"mappings":"AAAA,SAAS,cAAc,aAAa;AACpC,SAAS,cAAc;AACvB,MAAM,UAAS,GAAG,OAAO,aAAa;AAiBtC,MAAM,kBAAkB;AAAA,EACtB,MAAM,eAAe,EAAE,aAAa,UAAU,aAAa,YAAY,KAAK,GAA0B;AACpG,UAAM,WAAW,IAAI,SAAS;AAC9B,aAAS,OAAO,eAAe,OAAO,WAAW,CAAC;AAClD,aAAS,OAAO,YAAe,QAAQ;AACvC,aAAS,OAAO,eAAe,WAAW;AAC1C,aAAS,OAAO,cAAe,UAAU;AACzC,aAAS,OAAO,QAAe,IAAI;AAEnC,UAAM,EAAE,KAAK,IAAI,MAAM,MAAM,KAAK,SAAS,QAAQ;AACnD,WAAO;AAAA,EACT;AAAA,EAEA,MAAM,kBAAkB;AACtB,UAAM,EAAE,KAAK,IAAI,MAAM,MAAM,IAAI,OAAO;AACxC,WAAO;AAAA,EACT;AAAA,EAEA,MAAM,gBAAgB,IAAqB;AACzC,UAAM,EAAE,KAAK,IAAI,MAAM,MAAM,IAAI,GAAG,OAAO,IAAI,EAAE,EAAE;AACnD,WAAO;AAAA,EACT;AAAA,EAEA,MAAM,eAAe,IAAqB,EAAE,UAAU,aAAa,YAAY,KAAK,GAA0B;AAC5G,UAAM,WAAW,IAAI,SAAS;AAC9B,aAAS,OAAO,YAAe,QAAQ;AACvC,aAAS,OAAO,eAAe,WAAW;AAC1C,aAAS,OAAO,cAAe,UAAU;AACzC,QAAI,MAAM;AACR,eAAS,OAAO,QAAQ,IAAI;AAAA,IAC9B;AAEA,UAAM,EAAE,KAAK,IAAI,MAAM,MAAM,IAAI,GAAG,OAAO,IAAI,EAAE,IAAI,QAAQ;AAC7D,WAAO;AAAA,EACT;