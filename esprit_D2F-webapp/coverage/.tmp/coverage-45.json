ble\" },\n};\n\nexport default function ModelStatusBadge({ refreshKey = 0 }: Readonly<Props>) {\n  const { report, status } = useModelStatus(refreshKey);\n\n  const meta = STYLES[status];\n  const tooltip = report?.recommendation\n    || report?.message\n    || (report?.days_since_training === undefined\n        ? \"Statut du modèle prédictif\"\n        : `Entraîné il y a ${report.days_since_training} jours`);\n\n  return (\n    <Tooltip title={tooltip}>\n      <Tag color={meta.color} style={{ borderRadius: 12, padding: \"2px 10px\" }}>\n        <Space size={4}>\n          {meta.icon}\n          {meta.label}\n        </Space>\n      </Tag>\n    </Tooltip>\n  );\n}\n"],"mappings":"AAcsC;AAdtC,SAAS,KAAK,SAAS,aAAa;AACpC;AAAA,EACE;AAAA,EACA;AAAA,EACA;AAAA,EACA;AAAA,OACK;AACP,SAAS,sBAAwC;AAMjD,MAAM,SAAuF;AAAA,EAC3F,SAAU,EAAE,OAAO,WAAW,MAAM,uBAAC,uBAAoB,MAAI,QAAzB;AAAA;AAAA;AAAA;AAAA,SAA0B,GAAI,OAAO,gBAAgB;AAAA,EACzF,UAAU,EAAE,OAAO,UAAW,MAAM,uBAAC,+BAAD;AAAA;AAAA;AAAA;AAAA,SAA2B,GAAI,OAAO,mBAAmB;AAAA,EAC7F,OAAU,EAAE,OAAO,SAAW,MAAM,uBAAC,yBAAD;AAAA;AAAA;AAAA;AAAA,SAAqB,GAAU,OAAO,gBAAgB;AAAA,EAC1F,OAAU,EAAE,OAAO,UAAW,MAAM,uBAAC,yBAAD;AAAA;AAAA;AAAA;AAAA,SAAqB,GAAU,OAAO,gBAAgB;AAAA,EAC1F,OAAU,EAAE,OAAO,OAAW,MAAM,uBAAC,qBAAD;AAAA;AAAA;AAAA;AAAA,SAAiB,GAAc,OAAO,kBAAkB;AAAA,EAC5F,OAAU,EAAE,OAAO,WAAW,MAAM,uBAAC,+BAAD;AAAA;AAAA;AAAA;AAAA,SAA2B,GAAI,OAAO,sBAAsB;AAClG;AAEA,wBAAwB,iBAAiB,EAAE,aAAa,EAAE,GAAoB;AAC5E,QAAM,EAAE,QAAQ,OAAO,IAAI,eAAe,UAAU;AAEpD,QAAM,OAAO,OAAO,MAAM;AAC1B,QAAM,UAAU,QAAQ,kBACnB,QAAQ,YACP,QAAQ,wBAAwB,SAC9B,+BACA,mBAAmB,OAAO,mBAAmB;AAErD,SACE,uBAAC,WAAQ,OAAO,SACd,iCAAC,OAAI,OAAO,KAAK,OAAO,OAAO,EAAE,cAAc,IAAI,SAAS,WAAW,GACrE,iCAAC,SAAM,MAAM,GACV;AAAA,SAAK;AAAA,IACL,KAAK;AAAA,OAFR;AAAA;AAAA;AAAA;AAAA,SAGA,KAJF;AAAA;AAAA;AAAA;AAAA,SAKA,KANF;AAAA;AAAA;AAAA;AAAA,SAOA;AAEJ;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"b446000ab230bb943e74edb7bb1a5991e6f97756"}}