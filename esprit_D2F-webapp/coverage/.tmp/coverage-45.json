ery.isError),\r\n    [query.data, query.isError]\r\n  );\r\n\r\n  return {\r\n    report: query.data,\r\n    status,\r\n    isLoading: query.isLoading,\r\n    isError: query.isError,\r\n    error: query.error,\r\n    refetch: query.refetch,\r\n  };\r\n}"],"mappings":"AAAA,SAAS,eAAe;AACxB,SAAS,gBAAgB;AACzB,OAAO,8BAAoD;AAI3D,SAAS,cAAc,QAAiC,SAA+B;AACrF,MAAI,SAAS;AACX,WAAO;AAAA,EACT;AAEA,MAAI,CAAC,QAAQ;AACX,WAAO;AAAA,EACT;AAEA,QAAM,UAAU,OAAO,OAAO,WAAW,EAAE,EAAE,YAAY;AACzD,MAAI,QAAQ,SAAS,UAAU,KAAK,QAAQ,SAAS,aAAa,KAAK,QAAQ,SAAS,cAAc,GAAG;AACvG,WAAO;AAAA,EACT;AAEA,MAAI,OAAO,gBAAgB;AACzB,QAAI,OAAO,OAAO,wBAAwB,YAAY,OAAO,sBAAsB,IAAI;AACrF,aAAO;AAAA,IACT;AACA,WAAO;AAAA,EACT;AAEA,SAAO;AACT;AAEO,gBAAS,eAAe,aAAa,GAAG;AAC7C,QAAM,QAAQ,SAAsB;AAAA,IAClC,UAAU,CAAC,WAAW,gBAAgB,UAAU;AAAA,IAChD,SAAS,MAAM,yBAAyB,SAAS;AAAA,EACnD,CAAC;AAED,QAAM,SAAS;AAAA,IACb,MAAM,cAAc,MAAM,MAAM,MAAM,OAAO;AAAA,IAC7C,CAAC,MAAM,MAAM,MAAM,OAAO;AAAA,EAC5B;AAEA,SAAO;AAAA,IACL,QAAQ,MAAM;AAAA,IACd;AAAA,IACA,WAAW,MAAM;AAAA,IACjB,SAAS,MAAM;AAAA,IACf,OAAO,MAAM;AAAA,IACb,SAAS,MAAM;AAAA,EACjB;AACF;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"6c616d2b206de1b9c69cbc776c80134ee5654d3a"},"C:/Users/oussama/Desktop/pfe-d2f-enseignants/esprit_D2F-webapp/src/components/charts/ModelStatusBadge.tsx":{"path":"C:/Users/oussama/Desktop/pfe-d2f-enseignants/esprit_D2F-webapp/src/components/charts/ModelStatusBadge.tsx","statementMap":{"0":{"start":{"line":10,"column":15},"end":{"line":41,"column":1}},"1":{"start":{"line":43,"column":29},"end":{"line":43,"column":55}},"2":{"start":{"line":44,"column":15},"end":{"line":44,"column":29}},"3":{"start":{"line":45,"column":18},"end":{"line":45,"column":190}},"4":{"start":{"line":46,"column":2},"end":{"line":61,"column":11}}},"fnMap":{"0":{"name":"ModelStatusBadge","decl":{"start":{"line":42,"column":24},"end":{"line":42,"column":40}},"loc":{"start":{"line":42,"column":61},"end":{"line":62,"column":1}},"line":42}},"branchMap":{"0":{"loc":{"start":{"line"