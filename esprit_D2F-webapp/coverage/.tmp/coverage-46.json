tor } from \"@/models/analyse\";\r\r\n\r\r\nconst { Text } = Typography;\r\r\n\r\r\ninterface Props {\r\n  value?: string;\r\n  onChange: (id: string) => void;\r\n  teachers: TeacherRiskIndicator[];\r\n  loading?: boolean;\r\n  size?: \"small\" | \"middle\" | \"large\";\r\n}\r\r\n\r\r\ntype OptionData = { value: string; label: string; risk: number };\r\r\n\r\r\nfunction scoreColor(score: number): string {\r\n  if (score >= 0.7) return \"#ef4444\";\r\n  if (score >= 0.4) return \"#f59e0b\";\r\n  return \"#10b981\";\r\n}\r\r\n\r\r\nfunction TeacherOption({ data }: Readonly<{ data: OptionData }>) {\r\n  return (\r\n    <Space>\r\n      <Avatar size={20} icon={<UserOutlined />} style={{ backgroundColor: scoreColor(data.risk ?? 0) }} />\r\n      <Text>{data.label}</Text>\r\n      <Text type=\"secondary\" style={{ fontSize: 11 }}>{data.value}</Text>\r\n    </Space>\r\n  );\r\n}\r\r\n\r\r\nfunction renderTeacherOption(option: { data: OptionData }) {\r\n  return <TeacherOption data={option.data} />;\r\n}\r\r\n\r\r\nconst EnseignantSelect = memo(function EnseignantSelect({\r\n  value,\r\n  onChange,\r\n  teachers,\r\n  loading = false,\r\n  size = \"large\",\r\n}: Readonly<Props>) {\r\n  const options = useMemo(\r\n    () =>\r\n      teachers\r\n        .slice()\r\n        .sort((a, b) => a.teacher_name.localeCompare(b.teacher_name))\r\n        .map((t) => ({\r\n          value: t.teacher_id,\r\n          label: t.teacher_name || t.teacher_id,\r\n          risk: t.attrition_risk_score,\r\n        })),\r\n    [teachers]\r\n  );\r\r\n\r\r\n  return (\r\n    <Select\r\n      showSearch\r\n      allowClear\r\n      size={size}\r\n      value={value || undefined}\r\n      onChange={(v) => onChange(v || \"\")}\r\n      placeholder=\"Rechercher un enseignant (nom ou ID)\"\r\n      loading={loading}\r\n      style={{ width: \"100%\" }}\r\n      optionFilterProp=\"label\"\r\n      filterOption={(input, option) => {\r\n        if (!option) return false;\r\n        const t = input.toLowerCase();\r\n        return (\r\n          String(option.label).toLowerCase().includes(t) ||\r\n          String(option.value).toLowerCase().includes(t)\r\n        );\r\n      }}\r\n      optionRender={renderTeacherOption}\r\n      options={options}\r\n    />\r\n  );\r\n});\r\n\r\nexport default EnseignantSelect;\r\n"],"mappings":"AAoC8B;AApC9B,SAAS,MAAM,eAAe;AAC9B,SAAS,QAAQ,QAAQ,OAAO,kBAAkB;AAClD,SAAS,oBAAoB;AAK7B,MAAM,EAAE,KAAK,IAAI;AAkBjB,SAAS,WAAW,OAAuB;AACzC,MAAI,SAAS,IAAK,QAAO;AACzB,MAAI,SAAS,IAAK,QAAO;AACzB,SAAO;AACT;AAIA,SAAS,cAAc,EAAE,KAAK,GAAmC;AAC/D,SACE,uBAAC,SACC;AAAA,2BAAC,UAAO,MAAM,IAAI,MAAM,uBAAC,kBAAD;AAAA;AAAA;AAAA;AAAA,WAAc,GAAI,OAAO,EAAE,iBAAiB,WAAW,KAAK,QAAQ,CAAC,EAAE,KAA/F;AAAA;AAAA;AAAA;AAAA,WAAkG;AAAA,IAClG,uBAAC,QAAM,eAAK,SAAZ;AAAA;AAAA;AAAA;AAAA,WAAkB;AAAA,IAClB,uBAAC,QAAK,MAAK,aAAY,OAAO,EAAE,UAAU,GAAG,GAAI,eAAK,SAAtD;AAAA;AAAA;AAAA;AAAA,WAA4D;AAAA,OAH9D;AAAA;AAAA;AAAA;AAAA,SAIA;AAEJ;AAIA,SAAS,oBAAoB,QAA8B;AACzD,SAAO,uBAAC,iBAAc,MAAM,OAAO,QAA5B;AAAA;AAAA;AAAA;AAAA,SAAkC;AAC3C;AAIA,MAAM,mBAAmB,KAAK,SAASA,kBAAiB;AAAA,EACtD;AAAA,EACA;AAAA,EACA;AAAA,EACA,UAAU;AAAA,EACV,OAAO;AACT,GAAoB;AAClB,QAAM,UAAU;AAAA,IACd,MACE,SACG,MAAM,EACN,KAAK,CAAC,GAAG,MAAM,EAAE,aAAa,cAAc,EAAE,YAAY,CAAC,EAC3D,IAAI,CAAC,OAAO;AAAA,MACX,OAAO,EAAE;AAAA,MACT,OAAO,EAAE,gBAAgB,EAAE;AAAA,MAC3B,MAAM,EAAE;AAAA,IACV,EAAE;AAAA,IACN,CAAC,QAAQ;AAAA,EACX;AAIA,SACE;AAAA,IAAC;AAAA;AAAA,MACC,YAAU;AAAA,MACV,YAAU;AAAA,MACV;AAAA,MACA,OAAO,SAAS;AAAA,MAChB,UAAU,CAAC,MAAM,SAAS,KAAK,EAAE;AAAA,MACjC,aAAY;AAAA,MACZ;AAAA,MACA,OAAO,EAAE,OAAO,OAAO;AAAA,MACvB,kBAAiB;AAAA,MACjB,cAAc,CAAC,OAAO,WAAW;AAC/B,YAAI,CAAC,OAAQ,QAAO;AACpB,cAAM,IAAI,MAAM,YAAY;AAC5B,eACE,OAAO,OAAO,KAAK,EAAE,YAAY,EAAE,SAAS,CAAC,KAC7C,OAAO,OAAO,KAAK,EAAE,YAAY,EAAE,SAAS,CAAC;AAAA,MAEjD;AAAA,MACA,cAAc;AAAA,MACd;AAAA;AAAA,IAnBF;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,EAoBA;AAEJ,CAAC;AAED,eAAe;","names":["EnseignantSelect"]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"b070f881d67a8ce07344804eeda947c8dec6c93b"