"2":10,"3":5,"4":10,"5":10,"6":10,"7":10,"8":5,"9":10,"10":10,"11":10,"12":2,"13":1,"14":20},"b":{"0":[15,15],"1":[0,15],"2":[5,5],"3":[0,5],"4":[5,5],"5":[5,0],"6":[10,0],"7":[10,10,5],"8":[5,5],"9":[10,5],"10":[1,4],"11":[10,10]},"inputSourceMap":{"version":3,"sources":["C:/Users/oussama/Desktop/pfe-d2f-enseignants/esprit_D2F-webapp/src/components/charts/RiskTable.tsx"],"sourcesContent":["import { memo } from \"react\";\r\nimport { Table, Avatar, Tag, Space, Progress, Typography, Badge, Button, Tooltip } from \"antd\";\r\nimport { UserOutlined, ThunderboltOutlined } from \"@ant-design/icons\";\r\nimport type { TeacherRiskIndicator } from \"@/models/analyse\";\r\r\n\r\r\nconst { Text } = Typography;\r\r\n\r\r\nfunction riskColor(s: number): string {\r\n  if (s >= 0.7) return \"#ef4444\";\r\n  if (s >= 0.4) return \"#f59e0b\";\r\n  return \"#10b981\";\r\n}\r\r\n\r\r\nfunction badgeColor(v: number): string {\r\n  if (v > 3) return \"#10b981\";\r\n  if (v > 0) return \"#f59e0b\";\r\n  return \"#ef4444\";\r\n}\r\r\n\r\r\nfunction tagColor(v: string): string {\r\n  if (v === \"OK\") return \"green\";\r\n  if (v?.includes(\"entretien\")) return \"red\";\r\n  return \"orange\";\r\n}\r\r\n\r\r\ninterface Props {\r\n  data: TeacherRiskIndicator[];\r\n  threshold: number;\r\n  onAnalyze?: (teacherId: string) => void;\r\n}\r\r\n\r\r\nconst RiskTable = memo(function RiskTable({ data, threshold, onAnalyze }: Readonly<Props>) {\r\n  const columns = [\r\n    {\r\n      title: \"Enseignant\",\r\n      key: \"name\",\r\n      render: (_: unknown, r: TeacherRiskIndicator) => (\r\n        <Space>\r\n          <Avatar size=\"small\" icon={<UserOutlined />} style={{ backgroundColor: riskColor(r.attrition_risk_score) }} />\r\n          <div>\r\n            <Text strong>{r.teacher_name}</Text>\r\n            <br />\r\n            <Text type=\"secondary\" style={{ fontSize: 11 }}>{r.teacher_id}</Text>\r\n          </div>\r\n        </Space>\r\n      ),\r\n    },\r\n    {\r\n      title: \"Score Risque\",\r\n      dataIndex: \"attrition_risk_score\",\r\n      width: 160,\r\n      sorter: (a: TeacherRiskIndicator, b: TeacherRiskIndicator) => a.attrition_risk_score - b.attrition_risk_score,\r\n      defaultSortOrder: \"descend\" as const,\r\n      render: (v: number) => (\r\n        <Space direction=\"vertical\" size={0} style={{ width: \"100%\" }}>\r\n          <Progress percent={Math.round(v * 100)} size=\"small\" strokeColor={riskColor(v)} showInfo={false} />\r\n          <Text strong style={{ color: riskColor(v) }}>{(v * 100).toFixed(0)}%</Text>\r\n        </Space>\r\n      ),\r\n    },\r\n    {\r\n      title: \"Signaux\",\r\n      dataIndex: \"disengagement_signals\",\r\n      render: (signals: string[]) => (\r\n        <Space wrap size={4}>\r\n          {(signals || []).map((s) => (\r\n            <Tag key={s} color=\"volcano\" style={{ fontSize: 11 }}>{s}</Tag>\r\n          ))}\r\n          {(!signals || signals.length === 0) && <Tag color=\"green\">Aucun signal</Tag>}\r\n        </Space>\r\n      ),\r\n    },\r\n    {\r\n      title: \"Stagnation\",\r\n      dataIndex: \"competency_stagnation_rate\",\r\n      width: 100,\r\n      align: \"center\" as const,\r\n      render: (v: number) => (\r\n        <Text style={{ color: v > 0.5 ? \"#ef4444\" : \"#64748b\" }}>{(v * 100).toFixed(0)}%</Text>\r\n      ),\r\n    },\r\n    {\r\n      title: \"Formations\",\r\n      dataIndex: \"training_velocity\",\r\n      width: 100,\r\n      align: \"center\" as const,\r\n      render: (v: number) => (\r\n        <Badge\r\n          count={v || 0}\r\n          showZero\r\n          style={{ backgroundColor: badgeColor(v) }}\r\n        />\r\n      ),\r\n    },\r\n    {\r\n      title: \"Action\",\r\n      dataIndex: \"recommendation\",\r\n      width: 160,\r\n      render: (v: string) => (\r\n        <Tag color={tagColor(v)}>{v}</Tag>\r\n      ),\r\n    },\r\n    ...(onAnalyze\r\n      ? [{\r\n          title: \"\",\r\n          key: \"analyze\",\r\n          width: 56,\r\n          render: (_: unknown, r: TeacherRiskIndicator) => (\r\n            <Tooltip title=\"Lancer l'analyse individuelle\">\r\n              <Button\r\n                size=\"small\"\r\n                type=\"text\"\r\n                icon={<ThunderboltOutlined />}\r\n                onClick={() => onAnalyze(r.teacher_id)}\r\n              />\r\n            </Tooltip>\r\n          ),\r\n        }]\r\n      : []),\r\n  ];\r\r\n\r\r\n  return (\r\n    <Table<TeacherRiskIndicator>\r\n      dataSource={data}\r\n      columns={columns}\r\n      rowKey=\"teacher_id\"\r\n      pagination={{ pageSize: 8 }}\r\n      size=\"middle\"\r\n      rowClassName={(r) => (r.attrition_risk_score >= threshold ? \"risk-row-high\" : \"\")}\r\n    />\r\n  );\r\n});\r\n\r\nexport default RiskTable;\r\n"],"mappings":"AAkDqC;AAlDrC,SAAS,YAAY;AACrB,SAAS,OAAO,QAAQ,KAAK,OAAO,UAAU,YAAY,OAAO,QAAQ,eAAe;AACxF,SAAS,cAAc,2BAA2B;AAKlD,MAAM,EAAE,KAAK,IAAI;AAIjB,SAAS,UAAU,GAAmB;AACpC,MAAI,KAAK,IAAK,QAAO;AACrB,MAAI,KAAK,IAAK,QAAO;AACrB,SAAO;AACT;AAIA,SAAS,WAAW,GAAmB;AACrC,MAAI,IAAI,EAAG,QAAO;AAClB,MAAI,IAAI,EAAG,QAAO;AAClB,SAAO;AACT;AAIA,SAAS,SAAS,GAAmB;AACnC,MAAI,MAAM,KAAM,QAAO;AACvB,MAAI,GAAG,SAAS,WAAW,EAAG,QAAO;AACrC,SAAO;AACT;AAYA,MAAM,YAAY,KAAK,SAASA,WAAU,EAAE,MAAM,WAAW,UAAU,GAAoB;AACzF,QAAM,UAAU;AAAA,IACd;AAAA,MACE,OAAO;AAAA,MACP,KAAK;AAAA,MACL,QAAQ,CAAC,GAAY,MACnB,uBAAC,SACC;AAAA,+BAAC,UAAO,MAAK,SAAQ,MAAM,uBAAC,kBAAD;AAAA;AAAA;AAAA;AAAA,eAAc,GAAI,OAAO,EAAE,iBAAiB,UAAU,EAAE,oBAAoB,EAAE,KAAzG;AAAA;AAAA;AAAA;AAAA,eAA4G;AAAA,QAC5G,uBAAC,SACC;AAAA,iCAAC,QAAK,QAAM,MAAE,YAAE,gBAAhB;AAAA;AAAA;AAAA;AAAA,iBAA6B;AAAA,UAC7B,uBAAC,UAAD;AAAA;AAAA;AAAA;AAAA,iBAAI;AAAA,UACJ,uBAAC,QAAK,MAAK,aAAY,OAAO,EAAE,UAAU,GAAG,GAAI,YAAE,cAAnD;AAAA;AAAA;AAAA;AAAA,iBAA8D;AAAA,aAHhE;AAAA;AAAA;AAAA;AAAA,eAIA;AAAA,WANF;AAAA;AAAA;AAAA;AAAA,aAOA;AAAA,IAEJ;AAAA,IACA;AAAA,MACE,OAAO;AAAA,MACP,WAAW;AAAA,MACX,OAAO;AAAA,MACP,QAAQ,CAAC,GAAyB,MAA4B,EAAE,uBAAuB,EAAE;AAAA,MACzF,kBAAkB;AAAA,MAClB,QAAQ,CAAC,MACP,uBAAC,SAAM,WAAU,YA