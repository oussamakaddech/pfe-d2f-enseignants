const response = await axios.get(`${API_URL}/formations`, {\n        params: { startDate, endDate },\n      });\n      return normalizeListResponse(response.data);\n    } catch (error) {\n      throw error;\n    }\n  },\n\n  async getGlobalParticipantKPI(startDate: string, endDate: string) {\n    try {\n      const response = await axios.get(`${API_URL}/global`, {\n        params: { startDate, endDate },\n      });\n      return response.data;\n    } catch (error) {\n      throw error;\n    }\n  },\n};\n\nexport default ParticipantKPIService;\n\n\n\n\n"],"mappings":"AAAA,SAAS,cAAc,aAAa;AACpC,SAAS,cAAc;AAEvB,MAAM,UAAU,GAAG,OAAO,aAAa;AAEvC,SAAS,sBAAyB,SAAgE;AAChG,MAAI,MAAM,QAAQ,OAAO,GAAG;AAC1B,WAAO;AAAA,EACT;AAEA,MAAI,WAAW,OAAO,YAAY,UAAU;AAC1C,UAAM,YAAY;AAClB,QAAI,MAAM,QAAQ,UAAU,OAAO,GAAG;AACpC,aAAO,UAAU;AAAA,IACnB;AACA,QAAI,MAAM,QAAQ,UAAU,IAAI,GAAG;AACjC,aAAO,UAAU;AAAA,IACnB;AACA,QAAI,MAAM,QAAQ,UAAU,KAAK,GAAG;AAClC,aAAO,UAAU;AAAA,IACnB;AAAA,EACF;AAEA,SAAO,CAAC;AACV;AAEA,MAAM,wBAAwB;AAAA,EAC5B,MAAM,6BAA6B,WAAmB,SAAiB;AACrE,QAAI;AACF,YAAM,WAAW,MAAM,MAAM,IAAI,GAAG,OAAO,eAAe;AAAA,QACxD,QAAQ,EAAE,WAAW,QAAQ;AAAA,MAC/B,CAAC;AACD,aAAO,sBAAsB,SAAS,IAAI;AAAA,IAC5C,SAAS,OAAO;AACd,YAAM;AAAA,IACR;AAAA,EACF;AAAA,EAEA,MAAM,wBAAwB,WAAmB,SAAiB;AAChE,QAAI;AACF,YAAM,WAAW,MAAM,MAAM,IAAI,GAAG,OAAO,WAAW;AAAA,QACpD,QAAQ,EAAE,WAAW,QAAQ;AAAA,MAC/B,CAAC;AACD,aAAO,SAAS;AAAA,IAClB,SAAS,OAAO;AACd,YAAM;AAAA,IACR;AAAA,EACF;AACF;AAEA,eAAe;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"99bd4de5d49e2c7714fee1be86cecb82a27c84ff"}}