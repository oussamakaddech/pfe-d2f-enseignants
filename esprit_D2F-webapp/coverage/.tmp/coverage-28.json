ad)) {\n    return payload;\n  }\n\n  if (payload && typeof payload === \"object\") {\n    const candidate = payload as { content?: unknown; data?: unknown; items?: unknown };\n    if (Array.isArray(candidate.content)) {\n      return candidate.content;\n    }\n    if (Array.isArray(candidate.data)) {\n      return candidate.data;\n    }\n    if (Array.isArray(candidate.items)) {\n      return candidate.items;\n    }\n  }\n\n  return [];\n}\n\nconst BureauService = {\n  async getAllBureaux(): Promise<unknown[]> {\n    const response = await axios.get(API_URL);\n    return normalizeListResponse(response.data);\n  },\n\n  async getBureauById(id: number) {\n    const response = await axios.get(`${API_URL}/${id}`);\n    return response.data;\n  },\n\n  async createBureau(data: BureauRequest) {\n    const response = await axios.post(API_URL, data);\n    return response.data;\n  },\n\n  async updateBureau(id: number, data: BureauRequest) {\n    const response = await axios.put(`${API_URL}/${id}`, data);\n    return response.data;\n  },\n\n  async deleteBureau(id: number) {\n    await axios.delete(`${API_URL}/${id}`);\n  },\n};\n\nexport default BureauService;\n"],"mappings":"AAAA,SAAS,cAAc,aAAa;AACpC,SAAS,cAAc;AAGvB,MAAM,UAAU,GAAG,OAAO,aAAa;AAEvC,SAAS,sBAAsB,SAAkB;AAC/C,MAAI,MAAM,QAAQ,OAAO,GAAG;AAC1B,WAAO;AAAA,EACT;AAEA,MAAI,WAAW,OAAO,YAAY,UAAU;AAC1C,UAAM,YAAY;AAClB,QAAI,MAAM,QAAQ,UAAU,OAAO,GAAG;AACpC,aAAO,UAAU;AAAA,IACnB;AACA,QAAI,MAAM,QAAQ,UAAU,IAAI,GAAG;AACjC,aAAO,UAAU;AAAA,IACnB;AACA,QAAI,MAAM,QAAQ,UAAU,KAAK,GAAG;AAClC,aAAO,UAAU;AAAA,IACnB;AAAA,EACF;AAEA,SAAO,CAAC;AACV;AAEA,MAAM,gBAAgB;AAAA,EACpB,MAAM,gBAAoC;AACxC,UAAM,WAAW,MAAM,MAAM,IAAI,OAAO;AACxC,WAAO,sBAAsB,SAAS,IAAI;AAAA,EAC5C;AAAA,EAEA,MAAM,cAAc,IAAY;AAC9B,UAAM,WAAW,MAAM,MAAM,IAAI,GAAG,OAAO,IAAI,EAAE,EAAE;AACnD,WAAO,SAAS;AAAA,EAClB;AAAA,EAEA,MAAM,aAAa,MAAqB;AACtC,UAAM,WAAW,MAAM,MAAM,KAAK,SAAS,IAAI;AAC/C,WAAO,SAAS;AAAA,EAClB;AAAA,EAEA,MAAM,aAAa,IAAY,MAAqB;AAClD,UAAM,WAAW,MAAM,MAAM,IAAI,GAAG,OAAO,IAAI,EAAE,IAAI,IA