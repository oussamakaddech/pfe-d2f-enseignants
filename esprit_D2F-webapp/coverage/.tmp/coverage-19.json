,\r\n\r\n};\r\n\r\nexport default OneDriveService;\r\n\r\n\r\n\r\n\r\n"],"mappings":"AAAA,SAAS,cAAc,aAAa;AACpC,SAAS,cAAc;AACvB,MAAM,UAAU,GAAG,OAAO,aAAa;AAEvC,MAAM,kBAAkB;AAAA,EACtB,MAAM,oBAAoB;AACxB,QAAI;AACF,YAAM,WAAW,MAAM,MAAM,IAAI,GAAG,OAAO,YAAY;AACvD,aAAO,SAAS;AAAA,IAClB,SAAS,OAAO;AACd,YAAM;AAAA,IACR;AAAA,EACF;AAAA,EAEA,MAAM,aAAa,cAAsB,aAAqB,kBAA0B;AACtF,QAAI;AACF,YAAM,WAAW,MAAM,MAAM,IAAI,GAAG,OAAO,aAAa;AAAA,QACtD,QAAQ,EAAE,cAAc,aAAa,iBAAiB;AAAA,QACtD,cAAc;AAAA,MAChB,CAAC;AACD,aAAO,SAAS;AAAA,IAClB,SAAS,OAAO;AACd,YAAM;AAAA,IACR;AAAA,EACF;AAAA,EAEA,MAAM,WAAW,cAAsB,aAAqB,kBAA0B;AACpF,QAAI;AACF,YAAM,WAAW,MAAM,MAAM,OAAO,GAAG,OAAO,WAAW;AAAA,QACvD,QAAQ,EAAE,cAAc,aAAa,iBAAiB;AAAA,MACxD,CAAC;AACD,aAAO,SAAS;AAAA,IAClB,SAAS,OAAO;AACd,YAAM;AAAA,IACR;AAAA,EACF;AAAA,EACA,MAAM,aAAa,cAAsB,aAAqB;AAC5D,QAAI;AACF,YAAM,WAAW,MAAM,MAAM,IAAI,GAAG,OAAO,eAAe;AAAA,QACxD,QAAQ,EAAE,WAAW,cAAc,UAAU,YAAY;AAAA,MAC3D,CAAC;AACD,aAAO,SAAS;AAAA,IAClB,SAAS,OAAO;AACd,YAAM;AAAA,IACR;AAAA,EACF;AAAA,EACA,MAAM,sBAAsB,aAA8B;AACxD,QAAI;AACF,YAAM,EAAE,KAAK,IAAI,MAAM,MAAM;AAAA,QAC3B,GAAG,OAAO,eAAe,WAAW;AAAA,MACtC;AACA,aAAO;AAAA,IACT,SAAS,OAAO;AACd,YAAM;AAAA,IACR;AAAA,EACF;AAEF;AAEA,eAAe;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"8769b526805db41452e80ea8b2f382f648a2fae3"}}