13":1,"14":20},"b":{"0":[15,15],"1":[0,15],"2":[5,5],"3":[0,5],"4":[5,5],"5":[5,0],"6":[10,0],"7":[10,10,5],"8":[5,5],"9":[10,5],"10":[1,4],"11":[10,10]},"inputSourceMap":{"version":3,"sources":["C:/Users/oussama/Desktop/pfe-d2f-enseignants/esprit_D2F-webapp/src/components/charts/RiskTable.tsx"],"sourcesContent":["import { Table, Avatar, Tag, Space, Progress, Typography, Badge, Button, Tooltip } from \"antd\";\nimport { UserOutlined, ThunderboltOutlined } from \"@ant-design/icons\";\nimport type { TeacherRiskIndicator } from \"@/models/analyse\";\n\nconst { Text } = Typography;\n\nfunction riskColor(s: number): string {\n  if (s >= 0.7) return \"#ef4444\";\n  if (s >= 0.4) return \"#f59e0b\";\n  return \"#10b981\";\n}\n\nfunction badgeColor(v: number): string {\n  if (v > 3) return \"#10b981\";\n  if (v > 0) return \"#f59e0b\";\n  return \"#ef4444\";\n}\n\nfunction tagColor(v: string): string {\n  if (v === \"OK\") return \"green\";\n  if (v?.includes(\"entretien\")) return \"red\";\n  return \"orange\";\n}\n\ninterface Props {\n  data: TeacherRiskIndicator[];\n  threshold: number;\n  onAnalyze?: (teacherId: string) => void;\n}\n\nexport default function RiskTable({ data, threshold, onAnalyze }: Readonly<Props>) {\n  const columns = [\n    {\n      title: \"Enseignant\",\n      key: \"name\",\n      render: (_: unknown, r: TeacherRiskIndicator) => (\n        <Space>\n          <Avatar size=\"small\" icon={<UserOutlined />} style={{ backgroundColor: riskColor(r.attrition_risk_score) }} />\n          <div>\n            <Text strong>{r.teacher_name}</Text>\n            <br />\n            <Text type=\"secondary\" style={{ fontSize: 11 }}>{r.teacher_id}</Text>\n          </div>\n        </Space>\n      ),\n    },\n    {\n      title: \"Score Risque\",\n      dataIndex: \"attrition_risk_score\",\n      width: 160,\n      sorter: (a: TeacherRiskIndicator, b: TeacherRiskIndicator) => a.attrition_risk_score - b.attrition_risk_score,\n      defaultSortOrder: \"descend\" as const,\n      render: (v: number) => (\n        <Space direction=\"vertical\" size={0} style={{ width: \"100%\" }}>\n          <Progress percent={Math.round(v * 100)} size=\"small\" strokeColor={riskColor(v)} showInfo={false} />\n          <Text strong style={{ color: riskColor(v) }}>{(v * 100).toFixed(0)}%</Text>\n        </Space>\n      ),\n    },\n    {\n      title: \"Signaux\",\n      dataIndex: \"disengagement_signals\",\n      render: (signals: string[]) => (\n        <Space wrap size={4}>\n          {(signals || []).map((s) => (\n            <Tag key={s} color=\"volcano\" style={{ fontSize: 11 }}>{s}</Tag>\n          ))}\n          {(!signals || signals.length === 0) && <Tag color=\"green\">Aucun signal</Tag>}\n        </Space>\n      ),\n    },\n    {\n      title: \"Stagnation\",\n      dataIndex: \"competency_stagnation_rate\",\n      width: 100,\n      align: \"center\" as const,\n      render: (v: number) => (\n        <Text style={{ color: v > 0.5 ? \"#ef4444\" : \"#64748b\" }}>{(v * 100).toFixed(0)}%</Text>\n      ),\n    },\n    {\n      title: \"Formations\",\n      dataIndex: \"training_velocity\",\n      width: 100,\n      align: \"center\" as const,\n      render: (v: number) => (\n        <Badge\n          count={v || 0}\n          showZero\n          style={{ backgroundColor: badgeColor(v) }}\n        />\n      ),\n    },\n    {\n      title: \"Action\",\n      dataIndex: \"recommendation\",\n      width: 160,\n      render: (v: string) => (\n        <Tag color={tagColor(v)}>{v}</Tag>\n      ),\n    },\n    ...(onAnalyze\n      ? [{\n          title: \"\",\n          key: \"analyze\",\n          width: 56,\n          render: (_: unknown, r: TeacherRiskIndicator) => (\n            <Tooltip title=\"Lancer l'analyse individuelle\">\n              <Button\n                size=\"small\"\n                type=\"text\"\n                icon={<ThunderboltOutlined />}\n                onClick={() => onAnalyze(r.teacher_id)}\n              />\n            </Tooltip>\n          ),\n        }]\n      : []),\n  ];\n\n  return (\n    <Table<TeacherRiskIndicator>\n      dataSource={data}\n      columns={columns}\n      rowKey=\"teacher_id\"\n      pagination={{ pageSize: 8 }}\n      size=\"middle\"\n      rowClassName={(r) => (r.attrition_risk_score >= threshold ? \"risk-row-high\" : \"\")}\n    />\n  );\n}\n"],"mappings":"AAqCqC;AArCrC,SAAS,OAAO,QAAQ,KAAK,OAAO,UAAU,YAAY,OAAO,QAAQ,eAAe;AACxF,SAAS,cAAc,2BAA2B;AAGlD,MAAM,EAAE,KAAK,IAAI;AAEjB,SAAS,UAAU,GAAmB;AACpC,MAAI,KAAK,IAAK,QAAO;AACrB,MAAI,KAAK,IAAK,QAAO;AACrB,SAAO;AACT;AAEA,SAAS,WAAW,GAAmB;AACrC,MAAI,IAAI,EAAG,QAAO;AAClB,MAAI,IAAI,EAAG,QAAO;AAClB,SAAO;AACT;AAEA,SAAS,SAAS,GAAmB;AACnC,MAAI,MAAM,KAAM,QAAO;AACvB,MAAI,GAAG,SAAS,WAAW,EAAG,QAAO;AACrC,SAAO;AACT;AAQA,wBAAwB,UAAU,EAAE,MAAM,WAAW,UAAU,GAAoB;AACjF,QAAM,UAAU;AAAA,IACd;AAAA,MACE,OAAO;AAAA,MACP,KAAK;AAAA,MACL,QAAQ,CAAC,GAAY,MACnB,uBAAC,SACC;AAAA,+BAAC,UAAO,MAAK,SAAQ,MAAM,uBAAC,kBAAD;AAAA;AAAA;AAAA;AAAA,eAAc,GAAI,OAAO,EAAE,iBAAiB,UAAU,EAAE,oBAAoB,EAAE,KAAzG;AAAA;AAAA;AAAA;AAAA,eAA4G;AAAA,QAC5G,uBAAC,SACC;AAAA,iCAAC,QAAK,QAAM,MAAE,YAAE,gBAAhB;AAAA;AAAA;AAAA;AAAA,iBAA6B;AAAA,UAC7B,uBAAC,UAAD;AAAA;AAAA;AAAA;AAAA,iBAAI;AAAA,UACJ,uBAAC,QAAK,MAAK,aAAY,OAAO,EAAE,UAAU,GAAG,GAAI,YAAE,cAAnD;AAAA;AAAA;AAAA;AAAA,iBAA8D;AAAA,aAHhE;AAAA;AAAA;AAAA;AAAA,eAIA;AAAA,WANF;AAAA;AAAA;AAAA;AAAA,aAOA;AAAA,IAEJ;AAAA,IACA;AAAA,MACE,OAAO;AAAA,MACP,WAAW;AAAA,MACX,OAAO;AAAA,MACP,QAAQ,CAAC,GAAyB,MAA4B,EAAE,uBAAuB,EAAE;AAAA,MACzF,kBAAkB;AAAA,MAClB,QAAQ,CAAC,MACP,uBAAC,SAAM,WAAU,YAAW,MAAM,GAAG,OAAO,EAAE,OAAO,OAAO,GAC1D;AAAA,+BAAC,YAAS,SAAS,KAAK,MAAM,IAAI,GAAG,GAAG,MAAK,SAAQ,aAAa,UAAU,CAAC,GAAG,UAAU,SAA1F;AAAA;AAAA;AAAA;AAAA,eAAiG;AAAA,QACjG,uBAAC,QAAK,QAAM,MAAC,OAAO,EAAE,OAAO,UAAU,CAAC,EAAE,GAAK;AAAA,eAAI,KAAK,QAAQ,CAAC;AAAA,UAAE;AAAA,aAAnE;AAAA;AAAA;AAAA;AAAA,eAAoE;AAAA,WAFtE;AAAA;AAAA;AAAA;AAAA,aAGA;AAAA,IAEJ;AAAA,IACA;AAAA,MACE,OAAO;AAAA,MACP,WAAW;AAAA,MACX,QAAQ,CAAC,YACP,uBAAC,SAAM,MAAI,MAAC,MAAM,GACd;AAAA,oBAAW,CAAC,GAAG,IAAI,CAAC,MACpB,uBAAC,