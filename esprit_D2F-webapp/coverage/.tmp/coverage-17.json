],"5":[1,1,0],"6":[1,1,0]},"inputSourceMap":{"version":3,"sources":["C:/Users/oussama/Desktop/pfe-d2f-enseignants/esprit_D2F-webapp/src/services/besoin/BesoinFormationService.ts"],"sourcesContent":["import { defaultApi as axios } from \"@/utils/helpers/httpClient\";\nimport { config } from \"@/config/env\";\nimport type { Id, ApiListOrPage } from \"@/models/common\";\nimport type { BesoinFormation } from \"@/models/besoin\";\n\nconst API_URL = `${config.Besoin_URL}/besoins-formation`;\n\ninterface ModifyBesoinPayload {\n  besoinFormation: Partial<BesoinFormation>;\n  commentaire: string;\n}\n\nexport interface BesoinNotification {\n  id?: Id;\n  message?: string;\n  read?: boolean;\n  createdAt?: string;\n  [key: string]: unknown;\n}\n\nconst BesoinFormationService = {\n  async getAllBesoinFormations(): Promise<BesoinFormation[]> {\n    const response = await axios.get<ApiListOrPage<BesoinFormation>>(`${API_URL}`);\n    return (response.data as { content?: BesoinFormation[] }).content ?? (response.data as BesoinFormation[]) ?? [];\n  },\n\n  async getBesoinFormation(id: Id): Promise<BesoinFormation> {\n    const response = await axios.get<BesoinFormation>(`${API_URL}/${id}`);\n    return response.data;\n  },\n\n  async addBesoinFormation(\n    besoin: Partial<BesoinFormation>\n  ): Promise<BesoinFormation> {\n    const response = await axios.post<BesoinFormation>(`${API_URL}`, besoin);\n    return response.data;\n  },\n\n  async removeBesoinFormation(id: Id): Promise<unknown> {\n    const response = await axios.delete(`${API_URL}/${id}`);\n    return response.data;\n  },\n\n  async modifyBesoinFormation(\n    besoinFormation: Partial<BesoinFormation>,\n    commentaire: string\n  ): Promise<BesoinFormation> {\n    const payload: ModifyBesoinPayload = {\n      besoinFormation,\n      commentaire,\n    };\n    const response = await axios.put<BesoinFormation>(`${API_URL}`, payload);\n    return response.data;\n  },\n\n  async getApprovedBesoinFormations(): Promise<BesoinFormation[]> {\n    const response = await axios.get<ApiListOrPage<BesoinFormation>>(`${API_URL}/approved`);\n    return (response.data as { content?: BesoinFormation[] }).content ?? (response.data as BesoinFormation[]) ?? [];\n  },\n\n  async approveBesoin(id: Id): Promise<BesoinFormation> {\n    const response = await axios.put<BesoinFormation>(`${API_URL}/${id}/approve`);\n    return response.data;\n  },\n\n  async getUserNotifications(username: string): Promise<BesoinNotification[]> {\n    const response = await axios.get<ApiListOrPage<BesoinNotification>>(`${API_URL}/notifications/${username}`);\n    return (response.data as { content?: BesoinNotification[] }).content ?? (response.data as BesoinNotification[]) ?? [];\n  },\n\n  async getBesoinsByUp(up: string): Promise<BesoinFormation[]> {\n    const response = await axios.get<ApiListOrPage<BesoinFormation>>(`${API_URL}/by-up/${up}`);\n    return (response.data as { content?: BesoinFormation[] }).content ?? (response.data as BesoinFormation[]) ?? [];\n  },\n\n  async getBesoinsByDepartement(departement: string): Promise<BesoinFormation[]> {\n    const response = await axios.get<ApiListOrPage<BesoinFormation>>(`${API_URL}/by-departement/${departement}`);\n    return (response.data as { content?: BesoinFormation[] }).content ?? (response.data as BesoinFormation[]) ?? [];\n  },\n\n  async getBesoinsByPriorite(): Promise<BesoinFormation[]> {\n    const response = await axios.get<ApiListOrPage<BesoinFormation>>(`${API_URL}/by-priorite`);\n    return (response.data as { content?: BesoinFormation[] }).content ?? (response.data as BesoinFormation[]) ?? [];\n  },\n\n  async getBesoinsByPrioriteLevel(priorite: string): Promise<BesoinFormation[]> {\n    const response = await axios.get<ApiListOrPage<BesoinFormation>>(`${API_URL}/by-priorite/${priorite}`);\n    return (response.data as { content?: BesoinFormation[] }).content ?? (response.data as BesoinFormation[]) ?? [];\n  },\n};\n\nexport default BesoinFormationService;\n"],"mappings":"AAAA,SAAS,cAAc,aAAa;AACpC,SAAS,cAAc;AAIvB,MAAM,UAAU,GAAG,OAAO,UAAU;AAepC,MAAM,yBAAyB;AAAA,EAC7B,MAAM,yBAAqD;AACzD,UAAM,WAAW,MAAM,MAAM,IAAoC,GAAG,OAAO,EAAE;AAC7E,WAAQ,SAAS,KAAyC,WAAY,SAAS,QAA8B,CAAC;AAAA,EAChH;AAAA,EAEA,MAAM,mBAAmB,IAAkC;AACzD,UAAM,WAAW,MAAM,MAAM,IAAqB,GAAG,OAAO,IAAI,EAAE,EAAE;AACpE,WAAO,SAAS;AAAA,EAClB;AAAA,EAEA,MAAM,mBACJ,QAC0B;AAC1B,UAAM,WAAW,MAAM,MAAM,KAAsB,GAAG,OAAO,IAAI,MAAM;AACvE,WAAO,SAAS;AAAA,EAClB;AAAA,EAEA,MAAM,sBAAsB,IAA0B;AACpD,UAAM,WAAW,MAAM,MAAM,OAAO,GAAG,OAAO,IAAI,EAAE,EAAE;AACtD,WAAO,SAAS;AAAA,EAClB;AAAA,EAEA,MAAM,sBACJ,iBACA,aAC0B;AAC1B,UAAM,UAA+B;AAAA,MACnC;AAAA,MACA;AAAA,IACF;AACA,UAAM,WAAW,MAAM,MAAM,IAAqB,GAAG,OAAO,IAAI,OAAO;AACvE,WAAO,SAAS;AAAA,EAClB;AAAA,EAEA,MAAM,8BAA0D;AAC9D,UAAM,WAAW,MAAM,MAAM,IAAoC,GAAG,OAAO,WAAW;AACtF,WAAQ,SAAS,KAAyC,WAAY,SAAS,QAA8B,CAAC;AAAA,EAChH;AAAA,EAEA,MAAM,cAAc,IAAkC;AACpD,UAAM,WAAW,MAAM,MAAM,IAAqB,GAAG,OAAO,IAAI,EAAE,UAAU;AAC5E,WAAO,SAAS;AAAA,EAClB;AAAA,EAEA,MAAM,qBAAqB,UAAiD;AAC1E,UAAM,WAAW,MAAM,MAAM,IAAuC,GAAG,OAAO,kBAAkB,QAAQ,EAAE;AAC1G,WAAQ,SAAS,KAA4C,WAAY,SAAS,QAAiC,CAAC;AAAA,EACtH;AAAA,EAEA,MAAM,eAAe,IAAwC;AAC3D,UAAM,WAAW,MAAM,MAAM,IAAoC,GAAG,OAAO,UAAU,EAAE,EAAE;AACzF,WAAQ,SAAS,KAAyC,WAAY,SAAS,QAA8B,CAAC;AAAA,EAChH;AAAA,EAEA,MAAM,wBAAwB,aAAiD;AAC7E,UAAM,WAAW,MAAM,MAAM,IAAoC,GAAG,OAAO,mBAAmB,WAAW,EAAE;AAC3G,WAAQ,SAAS,KAAyC,WAAY,SAAS,QAA8B,CAAC;AAAA,EAChH;AAAA,EAEA,MAAM,uBAAmD;AACvD,UAAM,WAAW,MAAM,MAAM,IAAoC,GAAG,OAAO,cAAc;AACzF,WAAQ,SAAS,KAAyC,WAAY,SAAS,QAA8B,CAAC;AAAA,EAChH;AAAA,EAEA,MAAM,0BAA0B,UAA8C;AAC5E,UAAM,WAAW,MAAM,MAAM,IAAoC,GAAG,OAAO,gBAAgB,QAAQ,EAAE;AACrG,WAAQ,SAAS,KAAyC,WAAY,SAAS,QAA8B,CAAC;AAAA,EAChH;AACF;AAEA,eAAe;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"fb906549d1acb6be72e1daceb4e1633313d8d113"}}