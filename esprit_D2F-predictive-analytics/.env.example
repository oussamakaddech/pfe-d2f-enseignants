# D2F Predictive Analytics — Environment Configuration
APP_NAME=d2f-predictive-analytics
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (accès lecture/écriture sur la base D2F partagée)
DATABASE_URL=postgresql://app_user_analyse:analyse_pass@localhost:7432/d2f
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ML Model Settings
MODELS_DIR=data/models
GAP_MODEL_FILE=gap_predictor.joblib
RISK_MODEL_FILE=risk_detector.joblib
PREDICTION_HORIZON_MONTHS=6
MIN_TRAINING_SAMPLES=50
CV_FOLDS=5

# Gap Detection Thresholds
SEUIL_GAP_CRITIQUE=0.75
SEUIL_GAP_HAUTE=0.50
SEUIL_STAGNATION_MOIS=12
SEUIL_COMPLETION_FAIBLE=40.0
SEUIL_DEPT_PCT=0.30

# Risk Detection
RISK_GAP_THRESHOLD=2.0
RISK_ABSENCE_THRESHOLD_DAYS=365
RISK_ENGAGEMENT_PERCENTILE=10.0

# Scheduler
SCHEDULER_ENABLED=true
BATCH_ANALYSIS_HOUR=2
DASHBOARD_REFRESH_HOUR=3

# Messaging ActiveMQ (désactivé par défaut)
MESSAGING_ENABLED=false
ACTIVEMQ_HOST=localhost
ACTIVEMQ_STOMP_PORT=61613
ACTIVEMQ_USER=admin
ACTIVEMQ_PASSWORD=admin

# JWT (même secret que les autres microservices)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS512
JWT_AUTH_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
