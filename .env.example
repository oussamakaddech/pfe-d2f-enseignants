# ──────────────────────────────────────────────────────────────────────────────
# .env.example — Plateforme D2F
# Copier ce fichier en .env et remplir les valeurs avant le démarrage.
# NE JAMAIS commiter le fichier .env contenant des secrets dans Git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de données (PostgreSQL) ─────────────────────────────────────────────
POSTGRES_USER=d2f
POSTGRES_PASSWORD=                          # ← REMPLIR : superuser bootstrap (≥ 16 chars)
POSTGRES_DB=d2f

# Superuser bootstrap (utilisé uniquement par les scripts d'init et le seed)
DB_URL=jdbc:postgresql://postgres:5432/d2f
DB_PASSWORD=                                # ← REMPLIR : même valeur que POSTGRES_PASSWORD

# DSI §3.4 — Utilisateurs PostgreSQL par service (convention app_user_{service})
DB_USER_AUTH=app_user_auth
DB_USER_COMPETENCE=app_user_competence
DB_USER_FORMATION=app_user_formation
DB_USER_EVALUATION=app_user_evaluation
DB_USER_CERTIFICAT=app_user_certificat
DB_USER_BESOIN=app_user_besoinsformation
DB_USER_ANALYSE=app_user_analyse

# DSI §3.4 — Mots de passe par service (un secret distinct par rôle)
# À défaut, fallback sur DB_PASSWORD (cf. POSTGRES_INITDB_ARGS dans docker-compose.yml).
DB_PASSWORD_AUTH=                           # ← REMPLIR
DB_PASSWORD_FORMATION=                      # ← REMPLIR
DB_PASSWORD_BESOIN=                         # ← REMPLIR
DB_PASSWORD_EVALUATION=                     # ← REMPLIR
DB_PASSWORD_CERTIFICAT=                     # ← REMPLIR
DB_PASSWORD_COMPETENCE=                     # ← REMPLIR
DB_PASSWORD_ANALYSE=                        # ← REMPLIR

# ── JWT ──────────────────────────────────────────────────────────────────────
# Clé HS512 min 64 caractères. Générer avec : openssl rand -base64 64
JWT_SECRET=                                 # ← REMPLIR : clé secrète JWT

# ── Sécurité — Admin par défaut ──────────────────────────────────────────────
# DSI §10 — mot de passe fort exigé (min 12 chars, rejet de admin/admin123 en prod)
APP_SECURITY_DEFAULT_ADMIN_USERNAME=admin
APP_SECURITY_DEFAULT_ADMIN_PASSWORD=        # ← REMPLIR : mot de passe fort (min 12 chars)

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
# DSI §2 — hostname standard : broker.dsi.local (résolu par alias Docker en local)
RABBITMQ_HOST=broker.dsi.local
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=d2f
RABBITMQ_PASSWORD=                          # ← REMPLIR : mot de passe RabbitMQ

# ── CORS ─────────────────────────────────────────────────────────────────────
# DSI §10 — production : remplacer par le domaine interne DSI (ex: https://d2f.esprit.tn)
CORS_ORIGIN_WEBAPP=http://localhost:5173
CORS_ORIGIN_WEBAPP_ALT=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Mail (SMTP interne DSI obligatoire) ──────────────────────────────────────
# DSI §2 — serveur SMTP interne (jamais smtp.office365.com en dehors de AZURE_AD_ENABLED=true)
MAIL_HOST=smtp.internal.dsi.local
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@d2f.local
ADMIN_EMAIL=admin@d2f.local

# ── Formation — organisateur calendrier ──────────────────────────────────────
# DSI §1.1 — externalisé (ne jamais mettre en dur dans le code)
FORMATION_ORGANIZER_EMAIL=noreply@d2f.local

# ── Azure AD (Formation – Microsoft Graph — DÉSACTIVÉ par défaut) ────────────
# DSI §4/§2 — activer UNIQUEMENT sur décision DSI avec intégration Microsoft 365 autorisée.
# Mettre AZURE_AD_ENABLED=true pour activer calendrier Outlook, Teams et OneDrive.
AZURE_AD_ENABLED=false
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_GRAPH_SCOPE=https://graph.microsoft.com/.default
AZURE_AD_MAIL_USERNAME=
AZURE_AD_MAIL_PASSWORD=

# ── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api
VITE_RICE_URL=http://localhost:8001

# ── Services URLs (pour analyse inter-services) ─────────────────────────────
AUTH_SERVICE_URL=http://d2f-auth:8085
EVALUATION_SERVICE_URL=http://d2f-evaluation:8087
FORMATION_SERVICE_URL=http://d2f-formation:8088
COMPETENCE_SERVICE_URL=http://d2f-competence:8005
BESOIN_SERVICE_URL=http://d2f-besoin-formation:8004
CERTIFICAT_SERVICE_URL=http://d2f-certificat:8086
ANALYSE_SERVICE_URL=http://d2f-predictive-analytics:8000

# ── Predictive Analytics — seuils externalisés (DSI §1.1) ────────────────────
DB_USER_ANALYSE=app_user_analyse
SEUIL_GAP_CRITIQUE=0.75
SEUIL_GAP_HAUTE=0.50
SEUIL_STAGNATION_MOIS=12
SEUIL_COMPLETION_FAIBLE=40.0
SCHEDULER_ENABLED=true
BATCH_ANALYSIS_HOUR=2
DASHBOARD_REFRESH_HOUR=3
MESSAGING_ENABLED=false
