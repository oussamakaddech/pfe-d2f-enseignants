# =============================================================================
# .env.example — D2F Platform
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs sensibles.
#
#   cp .env.example .env
#
# IMPORTANT : Ne jamais committer le fichier .env dans Git.
#             Le fichier .env.example DOIT rester dans Git (sans valeurs réelles).
#
# Conformité DSI §1.1 : Absence de Hard-Coding
# =============================================================================


# =============================================================================
# JWT — Obligatoire pour TOUS les microservices
# =============================================================================
# Secret utilisé pour signer les tokens JWT (algorithme HS512).
# Longueur minimale : 64 caractères.
# Générer un secret sécurisé : openssl rand -base64 64
JWT_SECRET=


# =============================================================================
# Base de données PostgreSQL
# =============================================================================
# Mot de passe du user PostgreSQL principal (d2f)
DB_PASSWORD=

# Users applicatifs par service (conformité DSI §2 : app_user_{service_name})
DB_USER_AUTH=app_user_auth
DB_USER_COMPETENCE=app_user_competence
DB_USER_BESOIN=app_user_besoinsformation
DB_USER_CERTIFICAT=app_user_certificat
DB_USER_EVALUATION=app_user_evaluation


# =============================================================================
# ActiveMQ Artemis (Message Broker)
# =============================================================================
ARTEMIS_USER=admin
ARTEMIS_PASSWORD=


# =============================================================================
# Mail (service d'authentification)
# =============================================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=


# =============================================================================
# Frontend (webapp React)
# =============================================================================
# URL de base de l'API Gateway exposée au navigateur
VITE_API_URL=http://localhost:8222
VITE_RICE_URL=http://localhost:8222
